    // camera position
    const cx=Math.sin(phi)*Math.sin(theta);
    const cy=Math.cos(phi);
    const cz=Math.sin(phi)*Math.cos(theta);
    // right = cam × up-ish
    const rx=Math.cos(theta),ry=0,rz=-Math.sin(theta);
    // up = cam × right (Gram-Schmidt sketch)
    const ux=cy*rz-cz*ry, uy=cz*rx-cx*rz, uz=cx*ry-cy*rx;
    const ul=Math.sqrt(ux*ux+uy*uy+uz*uz);
    return{cx,cy,cz,rx,ry,rz,ux:ux/ul,uy:uy/ul,uz:uz/ul};
