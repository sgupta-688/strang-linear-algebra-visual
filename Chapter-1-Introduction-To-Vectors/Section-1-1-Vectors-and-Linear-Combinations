<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Section 1.1 – Vectors & Linear Combinations</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Source+Code+Pro:wght@400;600&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f8f4ee;--ink:#1c1812;--muted:#7a6e62;--panel:#ede8df;--border:#cfc4b0;
  --red:#c0392b;--blue:#1a5fa8;--green:#1a8a3c;--orange:#d4560a;--purple:#7c3aed;
}
body{font-family:'Lora',Georgia,serif;background:var(--bg);color:var(--ink);padding:16px;font-size:15px}
h1{font-size:1.4rem;font-weight:600;text-align:center;margin-bottom:4px}
.subtitle{text-align:center;font-style:italic;color:var(--muted);font-size:.9rem;margin-bottom:20px}
.section-nav{display:flex;overflow-x:auto;gap:4px;margin-bottom:18px;padding-bottom:4px}
.nav-btn{white-space:nowrap;padding:6px 14px;border:1.5px solid var(--border);background:white;border-radius:20px;font-family:'Lora',serif;font-size:.82rem;cursor:pointer;color:var(--muted);transition:all .15s}
.nav-btn.active{background:var(--ink);color:white;border-color:var(--ink)}
.panel{display:none;flex-direction:column;gap:16px}
.panel.active{display:flex}
.card{background:white;border:1.5px solid var(--border);border-radius:6px;padding:14px;box-shadow:2px 2px 0 var(--border)}
.card-title{font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:10px}
canvas{display:block;width:100%;height:auto;border-radius:4px}
.controls{display:flex;flex-direction:column;gap:10px}
.slider-row{display:flex;align-items:center;gap:10px}
.slider-row label{font-size:.88rem;min-width:90px;font-style:italic}
.slider-row input[type=range]{flex:1;height:3px;-webkit-appearance:none;border-radius:2px;outline:none;cursor:pointer}
.slider-row input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:15px;height:15px;border-radius:50%;background:var(--ink);border:2px solid white;box-shadow:0 1px 3px rgba(0,0,0,.3)}
.val{font-family:'Source Code Pro',monospace;font-size:.8rem;min-width:38px;text-align:right;font-weight:600}
.result-box{background:var(--panel);border:1px solid var(--border);border-radius:4px;padding:10px 12px;font-family:'Source Code Pro',monospace;font-size:.82rem;line-height:1.9}
.insight{background:#fff8f0;border-left:3px solid var(--orange);padding:10px 12px;font-style:italic;color:var(--muted);font-size:.88rem;line-height:1.6;border-radius:0 4px 4px 0}
.btn{padding:7px 14px;background:var(--ink);color:white;border:none;border-radius:4px;font-family:'Lora',serif;font-size:.83rem;cursor:pointer;transition:opacity .15s}
.btn:hover{opacity:.75}
.btn.on{background:var(--orange)}
.legend{display:flex;flex-wrap:wrap;gap:10px 18px;font-size:.82rem}
.leg{display:flex;align-items:center;gap:6px}
.leg-line{width:24px;height:3px;border-radius:2px}
.span-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.span-card{background:white;border:1.5px solid var(--border);border-radius:6px;padding:10px;text-align:center;box-shadow:2px 2px 0 var(--border)}
.span-card h3{font-size:.82rem;margin-bottom:6px}
.span-card p{font-size:.73rem;color:var(--muted);font-style:italic;line-height:1.5}
.span-icon{font-size:1.6rem;margin-bottom:6px}
.mode-row{display:flex;gap:8px;flex-wrap:wrap}
#cvs-3d{cursor:grab;touch-action:none;background:#111820;border-radius:4px}
#cvs-3d:active{cursor:grabbing}
</style>
</head>
<body>
<h1>Section 1.1: Vectors &amp; Linear Combinations</h1>
<p class="subtitle">Interactive visual guide — tap a topic to explore</p>

<div class="section-nav">
  <button class="nav-btn active" data-panel="add">Vector Addition</button>
  <button class="nav-btn" data-panel="scalar">Scalar Mult.</button>
  <button class="nav-btn" data-panel="combo">Lin. Combinations</button>
  <button class="nav-btn" data-panel="span">Span (2D)</button>
  <button class="nav-btn" data-panel="three">3D Vectors</button>
</div>

<!-- ── PANEL 1: Vector Addition ── -->
<div class="panel active" id="panel-add">
  <div class="card">
    <p class="card-title">Vector Addition: v + w (parallelogram rule)</p>
    <canvas id="cvs-add" width="580" height="380"></canvas>
    <div class="legend" style="margin-top:10px">
      <div class="leg"><div class="leg-line" style="background:var(--red)"></div> v = [4, 2]</div>
      <div class="leg"><div class="leg-line" style="background:var(--blue)"></div> w = [−1, 2]</div>
      <div class="leg"><div class="leg-line" style="background:var(--green)"></div> v + w = [3, 4]</div>
      <div class="leg"><div class="leg-line" style="background:var(--purple);opacity:.6"></div> w shifted to tip of v</div>
    </div>
  </div>
  <div class="insight"><strong>Parallelogram rule:</strong> place v and w tail-to-tail; the sum is the diagonal. Or put the tail of w at the tip of v — both routes arrive at v + w.</div>
  <div class="card">
    <p class="card-title">Subtraction: v − w = v + (−w)</p>
    <canvas id="cvs-sub" width="580" height="300"></canvas>
  </div>
  <div class="insight">Subtraction reverses w then adds. v − w is the <em>other</em> diagonal — running from the tip of w to the tip of v.</div>
</div>

<!-- ── PANEL 2: Scalar ── -->
<div class="panel" id="panel-scalar">
  <div class="card">
    <p class="card-title">Scaling a vector by scalar c</p>
    <canvas id="cvs-scalar" width="580" height="380"></canvas>
  </div>
  <div class="controls card">
    <p class="card-title">Adjust scalar c</p>
    <div class="slider-row">
      <label>scalar c</label>
      <input type="range" id="sl-c" min="-3" max="3" step="0.1" value="1" style="background:var(--red)">
      <span class="val" id="val-c" style="color:var(--red)">1.0</span>
    </div>
    <div class="result-box" id="scalar-result">c = 1.0 → cv = [2.0, 1.0]</div>
  </div>
  <div class="insight">c &gt; 1 stretches · 0 &lt; c &lt; 1 shrinks · c = 0 → zero vector · c &lt; 0 <em>reverses direction</em>. The number c is called a <strong>scalar</strong>.</div>
</div>

<!-- ── PANEL 3: Linear Combos ── -->
<div class="panel" id="panel-combo">
  <div class="card">
    <p class="card-title">cv + dw — adjust c and d freely</p>
    <canvas id="cvs-combo" width="580" height="420"></canvas>
    <div class="legend" style="margin-top:10px">
      <div class="leg"><div class="leg-line" style="background:var(--red)"></div> cv</div>
      <div class="leg"><div class="leg-line" style="background:var(--blue)"></div> dw</div>
      <div class="leg"><div class="leg-line" style="background:var(--green)"></div> cv + dw (result)</div>
    </div>
  </div>
  <div class="controls card">
    <p class="card-title">Adjust c and d</p>
    <div class="slider-row">
      <label>c (scales v)</label>
      <input type="range" id="sl-cv" min="-3" max="3" step="0.1" value="2" style="background:var(--red)">
      <span class="val" id="val-cv" style="color:var(--red)">2.0</span>
    </div>
    <div class="slider-row">
      <label>d (scales w)</label>
      <input type="range" id="sl-dw" min="-3" max="3" step="0.1" value="1" style="background:var(--blue)">
      <span class="val" id="val-dw" style="color:var(--blue)">1.0</span>
    </div>
    <div class="result-box" id="combo-result"></div>
  </div>
  <div class="insight">Four key special cases: sum (1,1) · difference (1,−1) · zero (0,0) · scalar multiple (c,0). All are linear combinations.</div>
</div>

<!-- ── PANEL 4: Span 2D ── -->
<div class="panel" id="panel-span">
  <div class="span-grid">
    <div class="span-card"><div class="span-icon">↗</div><h3>One vector cu</h3><p>Traces a <strong>line</strong> through the origin</p></div>
    <div class="span-card"><div class="span-icon">▱</div><h3>Two vectors cu+dv</h3><p>Fills the <strong>plane</strong> (if v ≠ cu)</p></div>
    <div class="span-card"><div class="span-icon">⬡</div><h3>Three in 3D</h3><p>Fills <strong>all of ℝ³</strong> (if independent)</p></div>
  </div>
  <div class="card">
    <p class="card-title">Watch combinations fill space</p>
    <canvas id="cvs-span" width="580" height="340"></canvas>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <button class="btn" id="btn-line">Line (1 vector)</button>
    <button class="btn" id="btn-plane">Plane (2 vectors)</button>
    <button class="btn" id="btn-dep">Dependent — same line!</button>
    <button class="btn" id="btn-clear-span">Clear</button>
  </div>
  <div class="insight" id="span-insight">Press a button. Key question: <em>does a new vector add a genuinely new direction?</em></div>
</div>

<!-- ── PANEL 5: 3D ── -->
<div class="panel" id="panel-three">
  <div class="card">
    <p class="card-title">3D vectors — drag to orbit · pinch/scroll to zoom</p>
    <canvas id="cvs-3d" width="600" height="460"></canvas>
  </div>
  <div class="controls card">
    <p class="card-title">Choose view</p>
    <div class="mode-row">
      <button class="btn on" id="btn3-vectors">Show u, v, w</button>
      <button class="btn" id="btn3-combo">Combination cu+dv+ew</button>
      <button class="btn" id="btn3-span">Span cloud</button>
    </div>
  </div>
  <div class="controls card" id="sliders-3d" style="display:none">
    <p class="card-title">Adjust scalars</p>
    <div class="slider-row">
      <label>c (scales u)</label>
      <input type="range" id="sl3-c" min="-2.5" max="2.5" step="0.1" value="1" style="background:#c0392b">
      <span class="val" id="v3-c" style="color:#c0392b">1.0</span>
    </div>
    <div class="slider-row">
      <label>d (scales v)</label>
      <input type="range" id="sl3-d" min="-2.5" max="2.5" step="0.1" value="1" style="background:#1a5fa8">
      <span class="val" id="v3-d" style="color:#1a5fa8">1.0</span>
    </div>
    <div class="slider-row">
      <label>e (scales w)</label>
      <input type="range" id="sl3-e" min="-2.5" max="2.5" step="0.1" value="1" style="background:#1a8a3c">
      <span class="val" id="v3-e" style="color:#1a8a3c">1.0</span>
    </div>
    <div class="result-box" id="res3d"></div>
  </div>
  <div class="insight" id="insight-3d">In 3D a vector has three components: v = [v₁, v₂, v₃]. It's still an arrow from the origin — the z-axis is the new direction you couldn't go in 2D.</div>
</div>

<script>
// ═══════════════════════════════════════════════
//  2D helpers
// ═══════════════════════════════════════════════
function mkCtx(id){const c=document.getElementById(id);return{c,ctx:c.getContext('2d'),W:c.width,H:c.height}}

function grid2(ctx,W,H,ox,oy,sc){
  ctx.save();ctx.strokeStyle='#ede8df';ctx.lineWidth=1;
  for(let i=-12;i<=12;i++){
    ctx.beginPath();ctx.moveTo(ox+i*sc,0);ctx.lineTo(ox+i*sc,H);ctx.stroke();
    ctx.beginPath();ctx.moveTo(0,oy-i*sc);ctx.lineTo(W,oy-i*sc);ctx.stroke();
  }
  ctx.strokeStyle='#bfb5a5';ctx.lineWidth=1.5;
  ctx.beginPath();ctx.moveTo(0,oy);ctx.lineTo(W,oy);ctx.stroke();
  ctx.beginPath();ctx.moveTo(ox,0);ctx.lineTo(ox,H);ctx.stroke();
  ctx.fillStyle='#bfb5a5';ctx.font='11px monospace';ctx.textAlign='center';
  for(let i=-8;i<=8;i++){if(i===0)continue;ctx.fillText(i,ox+i*sc,oy+14);}
  ctx.restore();
}

function arr2(ctx,x1,y1,x2,y2,col,w=2.5,al=1){
  const dx=x2-x1,dy=y2-y1,len=Math.sqrt(dx*dx+dy*dy);
  if(len<2)return;
  ctx.save();ctx.globalAlpha=al;ctx.strokeStyle=col;ctx.fillStyle=col;
  ctx.lineWidth=w;ctx.lineCap='round';
  const ux=dx/len,uy=dy/len,hw=8,hl=13;
  ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2-ux*hl,y2-uy*hl);ctx.stroke();
  ctx.beginPath();ctx.moveTo(x2,y2);
  ctx.lineTo(x2-ux*hl-uy*hw,y2-uy*hl+ux*hw);
  ctx.lineTo(x2-ux*hl+uy*hw,y2-uy*hl-ux*hw);
  ctx.closePath();ctx.fill();ctx.restore();
}
function dash2(ctx,x1,y1,x2,y2,col,al=.45){
  ctx.save();ctx.strokeStyle=col;ctx.lineWidth=1.5;ctx.setLineDash([5,4]);ctx.globalAlpha=al;
  ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();ctx.restore();
}
function lbl2(ctx,t,x,y,col,sz=14,st=''){ctx.save();ctx.fillStyle=col;ctx.font=`${st} ${sz}px Lora,Georgia,serif`;ctx.fillText(t,x,y);ctx.restore();}
function dot2(ctx,x,y,col,r=4){ctx.save();ctx.fillStyle=col;ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.fill();ctx.restore();}

// ═══════════════════════════════════════════════
//  Panel 1 — Addition
// ═══════════════════════════════════════════════
{
  const {ctx,W,H}=mkCtx('cvs-add');
  const ox=W*.38,oy=H*.62,sc=52,px=(x,y)=>[ox+x*sc,oy-y*sc];
  ctx.fillStyle='#fdfcfa';ctx.fillRect(0,0,W,H);
  grid2(ctx,W,H,ox,oy,sc);
  const [O0,O1]=px(0,0),[v0,v1]=px(4,2),[w0,w1]=px(-1,2),[r0,r1]=px(3,4);
  ctx.save();ctx.fillStyle='#eef4ff';ctx.globalAlpha=.35;
  ctx.beginPath();ctx.moveTo(O0,O1);ctx.lineTo(v0,v1);ctx.lineTo(r0,r1);ctx.lineTo(w0,w1);ctx.closePath();ctx.fill();ctx.restore();
  dash2(ctx,v0,v1,r0,r1,'#7c3aed');dash2(ctx,w0,w1,r0,r1,'#7c3aed');
  arr2(ctx,O0,O1,v0,v1,'#c0392b',3);
  arr2(ctx,O0,O1,w0,w1,'#1a5fa8',3);
  arr2(ctx,v0,v1,r0,r1,'#7c3aed',2,.65);
  arr2(ctx,O0,O1,r0,r1,'#1a8a3c',3.5);
  dot2(ctx,O0,O1,'#1c1812');
  lbl2(ctx,'v',v0+8,v1-6,'#c0392b',15,'italic');
  lbl2(ctx,'w',w0+8,w1-6,'#1a5fa8',15,'italic');
  lbl2(ctx,'v+w',r0+8,r1-6,'#1a8a3c',15,'italic');
  lbl2(ctx,'[4,2]',v0+10,v1+15,'#c0392b',11);
  lbl2(ctx,'[-1,2]',w0+10,w1-14,'#1a5fa8',11);
  lbl2(ctx,'[3,4]',r0+10,r1-8,'#1a8a3c',11);
}
{
  const {ctx,W,H}=mkCtx('cvs-sub');
  const ox=W*.38,oy=H*.62,sc=50,px=(x,y)=>[ox+x*sc,oy-y*sc];
  ctx.fillStyle='#fdfcfa';ctx.fillRect(0,0,W,H);
  grid2(ctx,W,H,ox,oy,sc);
  const [O0,O1]=px(0,0),[v0,v1]=px(4,2),[w0,w1]=px(-1,2),[nw0,nw1]=px(1,-2),[r0,r1]=px(5,0);
  arr2(ctx,O0,O1,v0,v1,'#c0392b',3);
  arr2(ctx,O0,O1,w0,w1,'#1a5fa8',2.5,.3);
  arr2(ctx,O0,O1,nw0,nw1,'#1a5fa8',2.5,.8);
  arr2(ctx,O0,O1,r0,r1,'#1a8a3c',3.5);
  dash2(ctx,w0,w1,v0,v1,'#1a8a3c');
  dot2(ctx,O0,O1,'#1c1812');
  lbl2(ctx,'v',v0+8,v1-6,'#c0392b',15,'italic');
  lbl2(ctx,'w',w0-26,w1-6,'#1a5fa8',13,'italic');
  lbl2(ctx,'-w',nw0+8,nw1+4,'#1a5fa8',13,'italic');
  lbl2(ctx,'v-w',r0+8,r1-6,'#1a8a3c',15,'italic');
  lbl2(ctx,'[5,0]',r0+8,r1+15,'#1a8a3c',11);
}

// ═══════════════════════════════════════════════
//  Panel 2 — Scalar
// ═══════════════════════════════════════════════
const BV=[2,1];
const sCtx=mkCtx('cvs-scalar');
function drawScalar(c){
  const {ctx,W,H}=sCtx;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fdfcfa';ctx.fillRect(0,0,W,H);
  const ox=W/2,oy=H/2,sc=52,px=(x,y)=>[ox+x*sc,oy-y*sc];
  grid2(ctx,W,H,ox,oy,sc);
  const [O0,O1]=px(0,0),[v0,v1]=px(BV[0],BV[1]);
  arr2(ctx,O0,O1,v0,v1,'#c0392b',2,.25);
  lbl2(ctx,'v',v0+6,v1-6,'#c0392b',12,'italic');
  const [cv0,cv1]=px(c*BV[0],c*BV[1]);
  arr2(ctx,O0,O1,cv0,cv1,'#c0392b',3.5);
  lbl2(ctx,`${c.toFixed(1)}v = [${(c*BV[0]).toFixed(1)}, ${(c*BV[1]).toFixed(1)}]`,cv0+(c>=0?10:-130),cv1-10,'#c0392b',12);
  dot2(ctx,O0,O1,'#1c1812');
}
drawScalar(1);
document.getElementById('sl-c').oninput=e=>{
  const c=parseFloat(e.target.value);
  document.getElementById('val-c').textContent=c.toFixed(1);
  document.getElementById('scalar-result').textContent=`c = ${c.toFixed(1)}  →  cv = [${(c*BV[0]).toFixed(2)}, ${(c*BV[1]).toFixed(2)}]`;
  drawScalar(c);
};

// ═══════════════════════════════════════════════
//  Panel 3 — Linear Combo
// ═══════════════════════════════════════════════
const LV=[1,1],LW=[2,3];let lc=2,ld=1;
const cCtx=mkCtx('cvs-combo');
function drawCombo(){
  const {ctx,W,H}=cCtx;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fdfcfa';ctx.fillRect(0,0,W,H);
  const ox=W/2,oy=H*.55,sc=44,px=(x,y)=>[ox+x*sc,oy-y*sc];
  grid2(ctx,W,H,ox,oy,sc);
  const cv=[lc*LV[0],lc*LV[1]],dw=[ld*LW[0],ld*LW[1]],res=[cv[0]+dw[0],cv[1]+dw[1]];
  const [O0,O1]=px(0,0),[cv0,cv1]=px(cv[0],cv[1]),[dw0,dw1]=px(dw[0],dw[1]),[r0,r1]=px(res[0],res[1]);
  dash2(ctx,cv0,cv1,r0,r1,'#1a5fa8');dash2(ctx,dw0,dw1,r0,r1,'#c0392b');
  arr2(ctx,O0,O1,cv0,cv1,'#c0392b',3);
  arr2(ctx,O0,O1,dw0,dw1,'#1a5fa8',3);
  arr2(ctx,O0,O1,r0,r1,'#1a8a3c',3.5);
  dot2(ctx,O0,O1,'#1c1812');
  lbl2(ctx,'cv',cv0+(lc>=0?8:-32),cv1-6,'#c0392b',14,'italic');
  lbl2(ctx,'dw',dw0+8,dw1-8,'#1a5fa8',14,'italic');
  lbl2(ctx,'cv+dw',r0+8,r1-8,'#1a8a3c',14,'italic');
  const rx=Math.round(res[0]*10)/10,ry=Math.round(res[1]*10)/10;
  document.getElementById('combo-result').innerHTML=
    `c=${lc.toFixed(1)}, d=${ld.toFixed(1)}<br>`+
    `cv=[${cv[0].toFixed(1)},${cv[1].toFixed(1)}]<br>`+
    `dw=[${dw[0].toFixed(1)},${dw[1].toFixed(1)}]<br>`+
    `<strong style="color:#1a8a3c">cv+dw = [${rx}, ${ry}]</strong>`;
}
drawCombo();
document.getElementById('sl-cv').oninput=e=>{lc=parseFloat(e.target.value);document.getElementById('val-cv').textContent=lc.toFixed(1);drawCombo();};
document.getElementById('sl-dw').oninput=e=>{ld=parseFloat(e.target.value);document.getElementById('val-dw').textContent=ld.toFixed(1);drawCombo();};

// ═══════════════════════════════════════════════
//  Panel 4 — Span 2D
// ═══════════════════════════════════════════════
const spCtx=mkCtx('cvs-span');
let spDots=[],spTimer=null,spCount=0;
function drawSpan(){
  const {ctx,W,H}=spCtx;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#fdfcfa';ctx.fillRect(0,0,W,H);
  const ox=W/2,oy=H/2,sc=44,px=(x,y)=>[ox+x*sc,oy-y*sc];
  grid2(ctx,W,H,ox,oy,sc);
  spDots.forEach(([x,y,col])=>{
    const [cx,cy]=px(x,y);
    ctx.save();ctx.fillStyle=col;ctx.globalAlpha=.2;
    ctx.beginPath();ctx.arc(cx,cy,3,0,Math.PI*2);ctx.fill();ctx.restore();
  });
  const [O0,O1]=px(0,0),[u0,u1]=px(1,1),[v0,v1]=px(2,0);
  arr2(ctx,O0,O1,u0,u1,'#c0392b',3);lbl2(ctx,'u=[1,1]',u0+8,u1-6,'#c0392b',12,'italic');
  arr2(ctx,O0,O1,v0,v1,'#1a5fa8',3);lbl2(ctx,'v=[2,0]',v0+8,v1-6,'#1a5fa8',12,'italic');
  dot2(ctx,O0,O1,'#1c1812');
}
drawSpan();
function startSweep(mode){
  if(spTimer)clearInterval(spTimer);spCount=0;
  spTimer=setInterval(()=>{
    for(let i=0;i<25;i++){
